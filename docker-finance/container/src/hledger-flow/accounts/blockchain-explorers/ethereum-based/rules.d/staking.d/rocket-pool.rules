# ---------------------------------------------------------------------------- #
#                                   Staking                                    #
# ---------------------------------------------------------------------------- #

# Staking committment can be treated as sending to self
if %direction ^OUT$
& %blockchain ^ethereum$
& %type ^normal$
& %amount_ [1-9]
& %to_address ^0x2fb42ffe2d7df8381853e96304300c6a5e846905$
  account2 assets:%account_name:%subaccount_name:%blockchain:%symbol
# TODO: consider removing from journal?
#  account1
#  account2

